# claude-code-slack configuration
# Copy this to config.env and fill in your values.
# NEVER commit config.env to git — it contains your Slack tokens.

# ─── Required ──────────────────────────────────────────────────────────────────

# Slack Bot OAuth Token (starts with xoxb-)
# Get from: api.slack.com → Your App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-

# Slack App-Level Token (starts with xapp-)
# Get from: api.slack.com → Your App → Basic Information → App-Level Tokens
# Requires the connections:write scope
SLACK_APP_TOKEN=xapp-

# Your Slack bot's user ID (looks like U0ABC1234)
# After installing the bot: send it a DM, click the message sender → "Copy member ID"
# Or check the OAuth & Permissions page in your Slack app dashboard
BOT_USER_ID=U

# Your own Slack user ID (the ONLY person allowed to run write/destructive operations)
# Find it: Slack → click your name in a message → "..." → "Copy member ID"
AUTHORIZED_USER_ID=U

# Display name for the authorized user (used in "Stopped by X." messages)
AUTHORIZED_USER_NAME=Owner

# ─── Optional ──────────────────────────────────────────────────────────────────

# Working directory where Claude sessions run.
# Set to your project directory to give Claude access to your codebase.
# Default: $HOME
# CLAUDE_WORKSPACE=$HOME/your-project

# Bot display name shown in logs and the Claude prompt
# BOT_NAME=ClaudeBot

# Forward new thread/DM starts to a tracking channel (leave empty to disable)
# FORWARD_CHANNEL=C

# Max concurrent Claude sessions (default: 10)
# MAX_PARALLEL=10

# Claude session timeout in seconds (default: 1800 = 30 min)
# CLAUDE_TIMEOUT=1800

# Context token cap before a thread session rotates to fresh (default: 400000)
# CONTEXT_CAP=400000

# Thread-continuous sessions:
#   0  = disabled, every mention spawns fresh (default)
#   dm = resume in DMs only
#   1  = resume everywhere (DMs + channels)
# RESUME_SESSIONS=1

# Pre-fetch thread context in the daemon before spawning the worker:
#   off    = disabled (default)
#   dm     = DMs only
#   1      = all
# PREFETCH_CONTEXT=dm

# ─── API Routing (advanced) ─────────────────────────────────────────────────────
# Leave blank to use the Claude CLI's own authentication (claude login).
# Set these only if routing through a proxy (Portkey, AWS Bedrock, etc.).

# ANTHROPIC_BASE_URL=https://api.portkey.ai
# ANTHROPIC_AUTH_TOKEN=your-token
# ANTHROPIC_CUSTOM_HEADERS=x-portkey-api-key: your-key
#                           x-portkey-provider: anthropic
