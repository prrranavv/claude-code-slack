[
  {
    "type": "header",
    "text": { "type": "plain_text", "text": "Debug: <component or error type>", "emoji": true }
  },
  { "type": "divider" },
  {
    "type": "rich_text",
    "elements": [
      {
        "type": "rich_text_section",
        "elements": [
          { "type": "text", "text": "Error\n", "style": { "bold": true } }
        ]
      },
      {
        "type": "rich_text_preformatted",
        "elements": [
          { "type": "text", "text": "ErrorType: short error message\n  at ClassName.method (file.ts:line)" }
        ]
      }
    ]
  },
  {
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*Root cause*\nExplanation of what went wrong and why."
    }
  },
  {
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": "*Fix*\nWhat was changed to resolve it. Reference `file.ts:line` if helpful."
    }
  },
  {
    "type": "context",
    "elements": [
      { "type": "mrkdwn", "text": "Status: ✅ Fixed  ·  ⚠️ Partially mitigated  ·  ❓ Needs investigation" }
    ]
  }
]
